# ============================================================
# IncuBrain Builder — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Variables prefixed NUXT_PUBLIC_ are exposed to the client.
# All others are server-only.
# ============================================================

# ---- Auth (Better Auth) ------------------------------------
# A random secret used to sign session cookies and JWE tokens.
# Generate one with: openssl rand -base64 32
NUXT_BETTER_AUTH_SECRET=change-me-to-a-random-string

# ---- GitHub OAuth ------------------------------------------
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to: <APP_URL>/api/auth/callback/github
NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=

# ---- Magic Link Email (optional) ---------------------------
# Sign up at https://resend.com to get an API key.
# If left empty, magic link URLs are logged to the console instead.
NUXT_RESEND_API_KEY=

# ---- Database (Turso / LibSQL) -----------------------------
# Local development uses a SQLite file — no signup required.
# For production, create a database at https://turso.tech
NUXT_TURSO_URL=file:./data/local.db
NUXT_TURSO_AUTH_TOKEN=

# ---- Public (exposed to client) ----------------------------
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_PUBLIC_APP_NAME=My App
